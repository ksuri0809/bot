-- Hàm tạo Tab
function OrionLib:MakeTab(Name, Icon)
    local TabButton = Instance.new("TextButton")
    TabButton.Name = Name.."Tab"
    TabButton.Parent = TabContainer
    TabButton.Size = UDim2.new(1, -10, 0, 35)
    TabButton.Position = UDim2.new(0, 5, 0, #TabContainer:GetChildren() * 40)
    TabButton.Text = " "..Icon.."  "..Name
    TabButton.TextColor3 = Color3.fromRGB(200, 200, 200)
    TabButton.Font = Enum.Font.GothamSemibold
    TabButton.TextSize = 13
    TabButton.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    TabButton.BackgroundTransparency = 0.3
    TabButton.TextXAlignment = Enum.TextXAlignment.Left
    
    local TabCorner = Instance.new("UICorner")
    TabCorner.CornerRadius = UDim.new(0, 6)
    TabCorner.Parent = TabButton
    
    local TabContent = Instance.new("Frame")
    TabContent.Name = Name.."Content"
    TabContent.Parent = ScrollFrame
    TabContent.Size = UDim2.new(1, -10, 0, 0)
    TabContent.BackgroundTransparency = 1
    TabContent.Visible = false
    
    local SectionList = Instance.new("UIListLayout")
    SectionList.Parent = TabContent
    SectionList.Padding = UDim.new(0, 5)
    
    local CurrentSection = nil
    
    -- Hàm tạo Section
    function TabContent:AddSection(Name)
        local Section = Instance.new("Frame")
        Section.Name = Name.."Section"
        Section.Parent = self
        Section.Size = UDim2.new(1, 0, 0, 0)
        Section.BackgroundColor3 = Color3.fromRGB(35, 35, 50)
        Section.BackgroundTransparency = 0.3
        
        local SectionCorner = Instance.new("UICorner")
        SectionCorner.CornerRadius = UDim.new(0, 8)
        SectionCorner.Parent = Section
        
        local SectionTitle = Instance.new("TextLabel")
        SectionTitle.Name = "SectionTitle"
        SectionTitle.Parent = Section
        SectionTitle.Size = UDim2.new(1, -10, 0, 25)
        SectionTitle.Position = UDim2.new(0, 5, 0, 5)
        SectionTitle.Text = Name
        SectionTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
        SectionTitle.Font = Enum.Font.GothamBold
        SectionTitle.TextSize = 14
        SectionTitle.BackgroundTransparency = 1
        SectionTitle.TextXAlignment = Enum.TextXAlignment.Left
        
        local ContentList = Instance.new("UIListLayout")
        ContentList.Parent = Section
        ContentList.Padding = UDim.new(0, 3)
        
        CurrentSection = Section
        return Section
    end
    
    -- Hàm tạo Toggle
    function TabContent:AddToggle(Name, Default, Callback)
        local Toggle = Instance.new("Frame")
        Toggle.Name = Name.."Toggle"
        Toggle.Parent = CurrentSection
        Toggle.Size = UDim2.new(1, -10, 0, 30)
        Toggle.Position = UDim2.new(0, 5, 0, 0)
        Toggle.BackgroundTransparency = 1
        
        local ToggleLabel = Instance.new("TextLabel")
        ToggleLabel.Parent = Toggle
        ToggleLabel.Size = UDim2.new(0.7, 0, 1, 0)
        ToggleLabel.Text = "  "..Name
        ToggleLabel.TextColor3 = Color3.fromRGB(220, 220, 220)
        ToggleLabel.Font = Enum.Font.Gotham
        ToggleLabel.TextSize = 12
        ToggleLabel.BackgroundTransparency = 1
        ToggleLabel.TextXAlignment = Enum.TextXAlignment.Left
        
        local ToggleButton = Instance.new("Frame")
        ToggleButton.Parent = Toggle
        ToggleButton.Size = UDim2.new(0, 35, 0, 18)
        ToggleButton.Position = UDim2.new(1, -40, 0.5, -9)
        ToggleButton.BackgroundColor3 = Default and Color3.fromRGB(80, 200, 120) or Color3.fromRGB(80, 80, 100)
        
        local ToggleRound = Instance.new("UICorner")
        ToggleRound.CornerRadius = UDim.new(1, 0)
        ToggleRound.Parent = ToggleButton
        
        local ToggleDot = Instance.new("Frame")
        ToggleDot.Parent = ToggleButton
        ToggleDot.Size = UDim2.new(0, 14, 0, 14)
        ToggleDot.Position = Default and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
        ToggleDot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        
        local DotRound = Instance.new("UICorner")
        DotRound.CornerRadius = UDim.new(1, 0)
        DotRound.Parent = ToggleDot
        
        local Toggled = Default
        
        ToggleButton.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                Toggled = not Toggled
                local goal = {}
                goal.BackgroundColor3 = Toggled and Color3.fromRGB(80, 200, 120) or Color3.fromRGB(80, 80, 100)
                local tween = TweenService:Create(ToggleButton, TweenInfo.new(0.2), goal)
                tween:Play()
                
                local dotGoal = {}
                dotGoal.Position = Toggled and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)
                local dotTween = TweenService:Create(ToggleDot, TweenInfo.new(0.2), dotGoal)
                dotTween:Play()
                
                Callback(Toggled)
            end
        end)
        
        return Toggle
    end
    
    -- Hàm tạo Button
    function TabContent:AddButton(Name, Callback)
        local Button = Instance.new("TextButton")
        Button.Name = Name.."Button"
        Button.Parent = CurrentSection
        Button.Size = UDim2.new(1, -10, 0, 30)
        Button.Position = UDim2.new(0, 5, 0, 0)
        Button.Text = Name
        Button.TextColor3 = Color3.fromRGB(255, 255, 255)
        Button.Font = Enum.Font.GothamSemibold
        Button.TextSize = 12
        Button.BackgroundColor3 = Color3.fromRGB(80, 120, 255)
        
        local ButtonCorner = Instance.new("UICorner")
        ButtonCorner.CornerRadius = UDim.new(0, 6)
        ButtonCorner.Parent = Button
        
        Button.MouseButton1Click:Connect(Callback)
        return Button
    end
    
    -- Hàm tạo Slider
    function TabContent:AddSlider(Name, Min, Max, Default, Callback)
        local Slider = Instance.new("Frame")
        Slider.Name = Name.."Slider"
        Slider.Parent = CurrentSection
        Slider.Size = UDim2.new(1, -10, 0, 50)
        Slider.Position = UDim2.new(0, 5, 0, 0)
        Slider.BackgroundTransparency = 1
        
        local SliderLabel = Instance.new("TextLabel")
        SliderLabel.Parent = Slider
        SliderLabel.Size = UDim2.new(1, 0, 0, 20)
        SliderLabel.Text = "  "..Name..": "..Default
        SliderLabel.TextColor3 = Color3.fromRGB(220, 220, 220)
        SliderLabel.Font = Enum.Font.Gotham
        SliderLabel.TextSize = 12
        SliderLabel.BackgroundTransparency = 1
        SliderLabel.TextXAlignment = Enum.TextXAlignment.Left
        
        local SliderBar = Instance.new("Frame")
        SliderBar.Parent = Slider
        SliderBar.Size = UDim2.new(1, -10, 0, 8)
        SliderBar.Position = UDim2.new(0, 5, 0, 25)
        SliderBar.BackgroundColor3 = Color3.fromRGB(60, 60, 80)
        
        local BarCorner = Instance.new("UICorner")
        BarCorner.CornerRadius = UDim.new(0, 4)
        BarCorner.Parent = SliderBar
        
        local SliderFill = Instance.new("Frame")
        SliderFill.Parent = SliderBar
        SliderFill.Size = UDim2.new((Default - Min) / (Max - Min), 0, 1, 0)
        SliderFill.BackgroundColor3 = Color3.fromRGB(100, 150, 255)
        
        local FillCorner = Instance.new("UICorner")
        FillCorner.CornerRadius = UDim.new(0, 4)
        FillCorner.Parent = SliderFill
        
        local SliderButton = Instance.new("TextButton")
        SliderButton.Parent = SliderBar
        SliderButton.Size = UDim2.new(0, 18, 0, 18)
        SliderButton.Position = UDim2.new((Default - Min) / (Max - Min), -9, 0.5, -9)
        SliderButton.Text = ""
        SliderButton.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        
        local ButtonCorner = Instance.new("UICorner")
        ButtonCorner.CornerRadius = UDim.new(1, 0)
        ButtonCorner.Parent = SliderButton
        
        local dragging = false
        local value = Default
        
        SliderButton.MouseButton1Down:Connect(function()
            dragging = true
        end)
        
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = false
            end
        end)
        
        UserInputService.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                local mousePos = UserInputService:GetMouseLocation()
                local barPos = SliderBar.AbsolutePosition
                local barSize = SliderBar.AbsoluteSize
                local relativeX = math.clamp(mousePos.X - barPos.X, 0, barSize.X)
                local percent = relativeX / barSize.X
                value = math.floor(Min + (Max - Min) * percent)
                
                SliderFill.Size = UDim2.new(percent, 0, 1, 0)
                SliderButton.Position = UDim2.new(percent, -9, 0.5, -9)
                SliderLabel.Text = "  "..Name..": "..value
                Callback(value)
            end
        end)
        
        return Slider
    end
    
    -- Click vào Tab để hiển thị nội dung
    TabButton.MouseButton1Click:Connect(function()
        for _, child in pairs(ScrollFrame:GetChildren()) do
            if child:IsA("Frame") then
                child.Visible = false
            end
        end
        TabContent.Visible = true
        
        for _, tab in pairs(TabContainer:GetChildren()) do
            if tab:IsA("TextButton") then
                tab.BackgroundTransparency = 0.3
            end
        end
        TabButton.BackgroundTransparency = 0
    end)
    
    -- Cập nhật kích thước Section
    CurrentSection.Size = UDim2.new(1, 0, 0, (#CurrentSection:GetChildren() * 35) + 30)
    
    return TabContent
end

