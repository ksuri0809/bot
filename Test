-- Tab ESP
local ESPTab = OrionLib:MakeTab("ESP", "👁️")

local ESPSection = ESPTab:AddSection("Cài Đặt ESP")

-- Lưu trữ ESP objects
local ESPObjects = {}
local ESPEnabled = false

-- Hàm tạo highlight
local function CreateESP(target)
    if target:FindFirstChild("ESPBox") then return end
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESPBox"
    highlight.Parent = target
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.FillColor = Color3.fromRGB(255, 0, 0)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESPName"
    billboard.Parent = target
    billboard.Size = UDim2.new(0, 100, 0, 20)
    billboard.AlwaysOnTop = true
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Parent = billboard
    nameLabel.Size = UDim2.new(1, 0, 1, 0)
    nameLabel.Text = target.Name.." ["..math.floor(target.Humanoid.Health).." HP]"
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.TextSize = 12
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.BackgroundTransparency = 1
    
    table.insert(ESPObjects, {target, highlight, billboard})
end

-- Hàm xóa ESP
local function ClearESP()
    for _, data in pairs(ESPObjects) do
        if data[2] then data[2]:Destroy() end
        if data[3] then data[3]:Destroy() end
    end
    ESPObjects = {}
end

ESPTab:AddToggle("Hiển Thị ESP", false, function(state)
    ESPEnabled = state
    if not state then
        ClearESP()
        return
    end
    
    spawn(function()
        while ESPEnabled do
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("Model") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 and v ~= LocalPlayer.Character then
                    CreateESP(v)
                end
            end
            wait(1)
        end
    end)
end)

