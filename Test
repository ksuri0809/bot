-- Hàm lấy người chơi
local function getPlayer()
    return game:GetService("Players").LocalPlayer
end

-- Hàm lấy nhân vật
local function getCharacter()
    return getPlayer().Character or getPlayer().CharacterAdded:Wait()
end

-- Hàm lấy vị trí hiện tại
local function getPosition()
    return getCharacter():FindFirstChild("HumanoidRootPart").CFrame
end

-- Hàm di chuyển đến vị trí
local function moveTo(cframe)
    local char = getCharacter()
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then
        hrp.CFrame = cframe
    end
end

-- Hàm lấy danh sách NPC
local function getNPCs()
    local npcs = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Humanoid") and v:FindFirstChild("Head") then
            if v:FindFirstChild("Humanoid").Health > 0 then
                table.insert(npcs, v)
            end
        end
    end
    return npcs
end

-- Hàm lấy danh sách nhiệm vụ NPC
local function getQuestNPCs()
    local questNPCs = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("Model") and v:FindFirstChild("Head") then
            if v:FindFirstChild("QuestHead") or v:FindFirstChild("QuestionMark") then
                table.insert(questNPCs, v)
            end
        end
    end
    return questNPCs
end

-- Hàm tìm NPC gần nhất theo tên
local function findNearestNPC(name)
    local nearest = nil
    local minDist = math.huge
    local pos = getPosition().Position
    for _, v in pairs(getNPCs()) do
        if v.Name:lower():find(name:lower()) then
            local dist = (v:FindFirstChild("Head").Position - pos).Magnitude
            if dist < minDist then
                minDist = dist
                nearest = v
            end
        end
    end
    return nearest
end

-- Hàm kiểm tra nhiệm vụ hiện tại
local function getCurrentQuest()
    local player = getPlayer()
    local questFolder = player:FindFirstChild("PlayerGui"):FindFirstChild("QuestGui")
    if questFolder then
        for _, v in pairs(questFolder:GetDescendants()) do
            if v:IsA("TextLabel") and v.Text ~= "" then
                return v.Text
            end
        end
    end
    return nil
end

-- Hàm nhận nhiệm vụ
local function acceptQuest(npc)
    if npc and npc:FindFirstChild("Head") then
        local pos = npc.Head.Position
        moveTo(CFrame.new(pos + Vector3.new(0, 3, 0)))
        task.wait(0.5)
        -- Giả lập nhấn E để nhận nhiệm vụ
        local vim = game:GetService("VirtualInputManager")
        vim:SendKeyEvent(true, Enum.KeyCode.E, false, game)
        task.wait(0.2)
        vim:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        task.wait(0.5)
    end
end

-- Hàm farm NPC mục tiêu
local function farmNPC(npc)
    if not npc then return end
    local char = getCharacter()
    local tool = char:FindFirstChildOfClass("Tool")
    if not tool then
        -- Tự động trang bị vũ khí
        local backpack = getPlayer().Backpack
        if #backpack:GetChildren() > 0 then
            local weapon = backpack:GetChildren()[1]
            char.Humanoid:EquipTool(weapon)
            task.wait(0.3)
            tool = char:FindFirstChildOfClass("Tool")
        end
    end
    
    -- Di chuyển đến NPC và tấn công
    if npc:FindFirstChild("Head") then
        moveTo(CFrame.new(npc.Head.Position + Vector3.new(0, 2, 2)))
        if tool and tool:FindFirstChild("Handle") then
            tool:Activate()
            task.wait(0.5)
            tool:Deactivate()
        end
    end
end

-- Hàm định vị NPC theo tên
local function locateNPC(name)
    local npc = findNearestNPC(name)
    if npc and npc:FindFirstChild("Head") then
        moveTo(CFrame.new(npc.Head.Position + Vector3.new(0, 50, 0)))
        return npc
    end
    return nil
end

-- Auto Farm Loop
local function autoFarmLoop()
    while AutoFarmEnabled do
        local success, err = pcall(function()
            -- Bước 1: Kiểm tra nhiệm vụ hiện tại
            local currentQuest = getCurrentQuest()
            
            if not currentQuest or currentQuest == "" then
                -- Bước 2: Không có nhiệm vụ -> Nhận nhiệm vụ mới
                local questNPCs = getQuestNPCs()
                if #questNPCs > 0 then
                    local questNPC = questNPCs[1]
                    acceptQuest(questNPC)
                    task.wait(1)
                end
            else
                -- Bước 3: Có nhiệm vụ -> Farm NPC theo nhiệm vụ
                local questText = currentQuest
                local npcName = ""
                
                -- Trích xuất tên NPC từ text nhiệm vụ
                if questText:find("defeat") then
                    npcName = questText:match("defeat (.+)") or questText:match("Defeat (.+)")
                elseif questText:find("kill") then
                    npcName = questText:match("kill (.+)") or questText:match("Kill (.+)")
                end
                
                if npcName and npcName ~= "" then
                    local target = findNearestNPC(npcName)
                    if target then
                        farmNPC(target)
                    else
                        -- Không tìm thấy NPC -> Định vị đến NPC
                        locateNPC(npcName)
                    end
                end
            end
        end)
        
        if not success then
            warn("Lỗi auto farm: " .. tostring(err))
        end
        
        task.wait(0.1)
    end
end

